# ---- Server ----
NODE_ENV=development
PORT=3000

# ---- Database (PostgreSQL) ----
# Required. Point this at a reachable Postgres instance before running migrations.
DATABASE_URL="postgresql://user:password@localhost:5432/lead_management?schema=public"

# ---- Auth ----
# Required. Use a long random string; must be >= 32 chars in production.
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# ---- CORS ----
CORS_ORIGIN=*

# ---- Webhooks (provider lead ingestion) ----
# Shared secret required in the `X-Webhook-Secret` header on every webhook call.
WEBHOOK_SECRET=change-this-webhook-secret
# Id of the user that owns leads created by webhooks (a "system" account).
# Use the seeded admin's id, or any valid user id. Get it after seeding, e.g.:
#   node -e "require('dotenv').config();const p=require('./src/core/prisma');p.user.findUnique({where:{email:'admin@lms.local'}}).then(u=>{console.log(u.id);return p.$disconnect()})"
WEBHOOK_SYSTEM_USER_ID=

# ---- Firebase Cloud Messaging (FCM) ----
# Optional. Leave blank until FCM is configured — the app skips Firebase init when unset.
# Service-account credentials (from the Firebase console > Project settings > Service accounts).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the PEM on one line with literal \n between lines, wrapped in quotes.
FIREBASE_PRIVATE_KEY=

# ---- Seed credentials (used by `npm run prisma:seed`) ----
SEED_ADMIN_NAME="Admin User"
SEED_ADMIN_EMAIL=admin@lms.local
SEED_ADMIN_PASSWORD=Admin@123
SEED_EMPLOYEE_NAME="Employee User"
SEED_EMPLOYEE_EMAIL=employee@lms.local
SEED_EMPLOYEE_PASSWORD=Employee@123
